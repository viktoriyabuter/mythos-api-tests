{
  "name": "mythos-api-tests",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "allure:clean": "node -e \"const fs=require('node:fs'); ['allure-results','allure-report'].forEach((dir)=>fs.rmSync(dir,{ recursive: true, force: true }));\"",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "allure:serve": "allure serve ./allure-results",
    "docker:allure:generate": "docker compose run --rm tests npm run allure:generate",
    "test": "playwright test",
    "test:auth": "playwright test --grep @auth",
    "test:allure": "npm run allure:clean && playwright test",
    "test:crud": "playwright test --grep @crud",
    "test:debug-demo": "node ./scripts/run-ignored-tests.mjs",
    "test:graphql": "playwright test --grep @graphql",
    "test:mock": "playwright test --grep @mock",
    "test:ui-example": "playwright test --grep @ui-example",
    "docker:build": "docker compose build tests",
    "docker:report": "docker compose run --rm --service-ports report",
    "docker:test": "docker compose run --rm tests",
    "docker:test:smoke": "docker compose run --rm tests npm run test:smoke",
    "test:negative": "playwright test --grep @negative",
    "test:read": "playwright test --grep @read",
    "test:smoke": "playwright test --grep @smoke",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "pw:install": "playwright install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.38.1",
    "allure-js-commons": "^3.7.1",
    "allure-playwright": "^3.7.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
