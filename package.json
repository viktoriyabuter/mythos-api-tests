{
  "name": "mythos-api-tests",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:auth": "playwright test --grep @auth",
    "test:crud": "playwright test --grep @crud",
    "test:debug-demo": "node ./scripts/run-ignored-tests.mjs",
    "docker:build": "docker compose build tests",
    "docker:report": "docker compose run --rm --service-ports report",
    "docker:test": "docker compose run --rm tests",
    "docker:test:smoke": "docker compose run --rm tests npm run test:smoke",
    "test:negative": "playwright test --grep @negative",
    "test:read": "playwright test --grep @read",
    "test:smoke": "playwright test --grep @smoke",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "pw:install": "playwright install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
